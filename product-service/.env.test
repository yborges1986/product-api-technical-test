# Variables de entorno para testing
NODE_ENV=test
PORT=3001

# Base de datos de testing
MONGODB_TEST_URI=mongodb://localhost:27017/treew_test

# JWT para testing (menos seguro, solo para tests)
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_EXPIRES_IN=24h

# Bcrypt (menos rounds para tests más rápidos)
BCRYPT_ROUNDS=10

# NATS (mockeado en tests)
NATS_URL=nats://localhost:4222

# Elasticsearch (opcional para tests de integración)
ELASTICSEARCH_NODE=http://localhost:9200
