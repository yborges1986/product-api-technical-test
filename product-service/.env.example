# Configuración del Microservicio de Gestión de Productos

# Puerto del servicio
PORT=3000

# Base de datos MongoDB
MONGODB_URI=mongodb://localhost:27017/product_management

# Entorno
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Configuración de CORS (para comunicación entre microservicios)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# Autenticación entre microservicios
SERVICE_TOKEN=your_service_secret_token_here

# JWT Secret (si implementas autenticación de usuarios)
# JWT_SECRET=your_jwt_secret_here

# Health check interval (en segundos)
HEALTH_CHECK_INTERVAL=30
